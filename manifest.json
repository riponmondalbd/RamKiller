{
  "manifest_version": 3,
  "name": "Ram Killer Pro",
  "version": "2.0",
  "description": "Auto suspend unused Chrome tabs with whitelist support.",
  "permissions": ["tabs", "storage", "alarms", "idle", "browsingData"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "mylogo.png",
      "48": "mylogo.png",
      "128": "mylogo.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "mylogo.png",
    "48": "mylogo.png",
    "128": "mylogo.png"
  }
}
